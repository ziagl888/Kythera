# Copy to .env and fill in. .env is gitignored.

# --- required secrets ---
TELEGRAM_BOT_TOKEN=123456:your-bot-token
# Health-Alerts des Watchdogs (Daten-Staleness/CPU/Outbox-Failures):
# private Chat-ID mit dem Bot. Bot einmal /start-en, ID z.B. via @userinfobot.
TELEGRAM_ALERT_CHAT_ID=
DB_NAME=cryptodata
DB_USER=dbfiller
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
BINANCE_API_KEY=
BINANCE_SECRET=

# --- rollout flags ---
# AIM2 (Bot 15): 0 = Shadow-only (Vorhersagen nur in ml_predictions_master),
# 1 = Live-Posting in CH_MASTER. Siehe docs/AIM2_DESIGN.md, Rollout-Gates.
AIM2_LIVE_POSTING=0
# Research-Bots 30-33 (PEX1/FMR1/TRM1/FIF1): 1 = Live-Posting in CH_NEW_IDEAS
# (Operator-Entscheid 2026-07-06: der Channel IST die Testumgebung),
# 0 = Shadow-only. Siehe docs/NEW_IDEAS_BOTS.md.
NEW_IDEAS_LIVE_POSTING=1
# MAX1 (Bot 34, High-Conviction-Drossel über RUB2-SHORT, T-2026-CU-9050-067):
# 0 = Shadow-only, 1 = Live-Posting in CH_MAX1 (Default-Fallback: CH_MAIN).
# Der Flip ist ein Operator-Entscheid. Siehe docs/MODEL_INTENT.md §8a.
MAX1_LIVE_POSTING=0
# Drossel-Parameter: Mindest-Probability (nie unter dem Artefakt-Threshold 0,829)
# und harte rollierende 24h-Kappe. Vorschlag aus der 044-Kurve: 0,93 → ~1,3/Tag.
MAX1_MIN_PROB=0.93
MAX1_MAX_PER_DAY=3

# --- telegram channel ids (one per posting target; -100XXXXXXXXXX) ---
CH_FAST_IN_OUT=-100XXXXXXXXXX
CH_5_PERCENT=-100XXXXXXXXXX
CH_MAIN=-100XXXXXXXXXX
CH_SUPPORT_RESISTANCE=-100XXXXXXXXXX
CH_VOLUME_INDICATOR=-100XXXXXXXXXX
