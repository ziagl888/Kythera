# Copy to .env and fill in. .env is gitignored.

# --- required secrets ---
TELEGRAM_BOT_TOKEN=123456:your-bot-token
# Health-Alerts des Watchdogs (Daten-Staleness/CPU/Outbox-Failures):
# private Chat-ID mit dem Bot. Bot einmal /start-en, ID z.B. via @userinfobot.
TELEGRAM_ALERT_CHAT_ID=
DB_NAME=cryptodata
DB_USER=dbfiller
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
BINANCE_API_KEY=
BINANCE_SECRET=

# --- rollout flags ---
# AIM2 (Bot 15): 0 = Shadow-only (Vorhersagen nur in ml_predictions_master),
# 1 = Live-Posting in CH_MASTER. Siehe docs/AIM2_DESIGN.md, Rollout-Gates.
AIM2_LIVE_POSTING=0

# --- telegram channel ids (one per posting target; -100XXXXXXXXXX) ---
