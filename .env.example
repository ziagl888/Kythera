CH_PUMP_AI=-100XXXXXXXXXX
CH_PUMP_MAIN=-100XXXXXXXXXX
CH_MIS_8H=-100XXXXXXXXXX
CH_MIS_24H=-100XXXXXXXXXX
CH_MIS_72H=-100XXXXXXXXXX
CH_MIS_168H=-100XXXXXXXXXX
CH_ATS=-100XXXXXXXXXX
CH_RUBBERBAND=-100XXXXXXXXXX
CH_ATB_TARGET=-100XXXXXXXXXX
CH_ATB_INFO=-100XXXXXXXXXX
CH_MASTER=-100XXXXXXXXXX
CH_SMC_METALS=-100XXXXXXXXXX
CH_SMC_FOREX=-100XXXXXXXXXX
